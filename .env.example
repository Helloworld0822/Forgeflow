# =============================================================================
# AutoForge — 환경 변수 예시
# 사용법: cp .env.example .env 후 값을 채워 넣으세요.
# =============================================================================

# -----------------------------------------------------------------------------
# 서버
# -----------------------------------------------------------------------------
HOST=0.0.0.0
PORT=8080
RUST_LOG=info

# -----------------------------------------------------------------------------
# AI API 키 (필수)
# -----------------------------------------------------------------------------
# Cursor Cloud Agents API — Summarize / Architect / Implement / Verify / Debug
CURSOR_API_KEY=

# Google Stitch MCP — Design 단계 UI 생성
STITCH_API_KEY=

# -----------------------------------------------------------------------------
# GitHub 자동화
# -----------------------------------------------------------------------------
# PAT (repo 권한) — 프라이빗 레포 자동 생성, PR 자동 머지
GITHUB_TOKEN=

# 조직 이름 (비우면 사용자 계정에 레포 생성)
GITHUB_ORG=

# SecurityPatch 통과 후 PR squash merge (기본: true)
GITHUB_AUTO_MERGE=true

# 웹 대시보드 공개 URL (Slack 일일 경과 링크)
PUBLIC_URL=http://localhost

# GitHub 미설정 시 구현 단계에 사용할 기존 레포 URL
DEFAULT_REPO_URL=

# -----------------------------------------------------------------------------
# 보안
# -----------------------------------------------------------------------------
# 설정 시 /v1/* API에 Authorization: Bearer <key> 인증을 강제한다.
# 운영 환경에서는 반드시 설정할 것 (미설정 시 API가 인증 없이 열려있음)
API_KEY=

# 웹 대시보드 세션 로그인 (아이디/비밀번호 1세트)
# 세 값이 모두 설정되면 브라우저에서 로그인 페이지로 접속할 수 있다.
LOGIN_USERNAME=
LOGIN_PASSWORD=
# 세션 쿠키 서명 키 (32자 이상 랜덤 문자열 권장)
SESSION_SECRET=

# CORS 허용 오리진 (콤마 구분, 예: https://app.example.com,https://admin.example.com)
# 미설정 시 모든 오리진 허용 (로컬 개발용)
CORS_ALLOWED_ORIGINS=

# 업로드 최대 크기 (bytes, 기본 50MB)
MAX_UPLOAD_BYTES=52428800

# -----------------------------------------------------------------------------
# 아티팩트 저장소 & 이미지 호스팅 (로컬 디스크)
# -----------------------------------------------------------------------------
# 파이프라인 산출물 + 업로드 이미지를 저장할 로컬 경로.
# Compose 환경에서는 api/worker/orchestrator가 공유하는 볼륨으로 마운트됩니다.
ARTIFACTS_DIR=./data/artifacts

# 이미지 업로드 최대 크기 (bytes, 기본 10MB)
MAX_IMAGE_BYTES=10485760

# -----------------------------------------------------------------------------
# 품질 게이트
# -----------------------------------------------------------------------------
# Verify 실패 시 Debug 재시도 횟수 (기본: 3)
MAX_DEBUG_CYCLES=3

# -----------------------------------------------------------------------------
# Redis 메시지 큐 (Podman 분산 배포)
# -----------------------------------------------------------------------------
# 로컬 단일 프로세스: false / Podman compose: true
MESSAGE_QUEUE_ENABLED=false

REDIS_URL=redis://127.0.0.1:6379
QUEUE_COMMANDS_STREAM=autoforge:commands
QUEUE_EVENTS_STREAM=autoforge:events
QUEUE_CONSUMER_GROUP=autoforge
# 프로세스당 동시 스테이지 실행 수 (MQ worker 컨테이너 1개 기준)
WORKER_CONCURRENCY=4
PODMAN_WORKER_IMAGE=localhost/autoforge-api:latest

# -----------------------------------------------------------------------------
# Compose (Docker / Podman)
# -----------------------------------------------------------------------------
# Podman rootless: ./scripts/podman-up.sh 가 IMAGE_PREFIX=localhost/ 를 자동 설정
# Docker: 비워두거나 주석 처리
# IMAGE_PREFIX=localhost/
# 기본 8080 (rootless Podman 호환). Docker에서 80번 쓰려면 HOST_HTTP_PORT=80
HOST_HTTP_PORT=8080

# Worker / Orchestrator 전용 (compose.yml에서 사용)
# STAGE_FILTER=implement
# WORKER_ID=worker-1
# ORCHESTRATOR_ID=orchestrator-1

# -----------------------------------------------------------------------------
# Slack 알림 (선택)
# -----------------------------------------------------------------------------
# Webhook 방식 (간단)
SLACK_WEBHOOK_URL=

# Bot Token + 채널 (스레드 업데이트용)
SLACK_BOT_TOKEN=
SLACK_CHANNEL=
